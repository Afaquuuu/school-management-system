generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/@prisma/tenant-client"
}

datasource db {
  provider = "postgresql"
  url = env("TENANT_DATABASE_URL")
}

enum UserRole {
  admin
  teacher
  student
  parent
}

enum Gender {
  male
  female
  other
}

enum AttendanceStatus {
  present
  absent
  late
  excused
}

enum InvoiceStatus {
  draft
  issued
  partially_paid
  paid
  overdue
  void
}

enum ExamStatus {
  draft
  scheduled
  completed
  cancelled
}

enum PaymentStatus {
  pending
  completed
  failed
  refunded
}

enum PaymentMethod {
  cash
  card
  bank_transfer
  mobile_money
  stripe
  paypal
}

enum DayOfWeek {
  monday
  tuesday
  wednesday
  thursday
  friday
  saturday
  sunday
}

enum AnnouncementPriority {
  low
  normal
  high
  urgent
}

enum MessageThreadType {
  direct
  group
  announcement
}

model User {
  id             String           @id @default(cuid())
  clerkId        String           @unique
  email          String           @unique
  name           String
  role           UserRole
  avatarUrl      String?
  phone          String?
  isActive       Boolean          @default(true)
  lastLoginAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  studentProfile StudentProfile?
  staffProfile   StaffProfile?
  guardianProfile GuardianProfile?

  announcements  Announcement[]
  messages       Message[]
  messageParticipants MessageParticipant[]
  notifications  Notification[]
  auditLogs      AuditLog[]
}

model AcademicYear {
  id          String        @id @default(cuid())
  label       String        @unique
  startsAt    DateTime
  endsAt      DateTime
  isActive    Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  classes     SchoolClass[]
  subjects    Subject[]
  classSubjectTeachers ClassSubjectTeacher[]
  timetables  TimetableSlot[]
  examCycles  ExamCycle[]
  exams       Exam[]
  feePlans    FeeStructure[]
}

model SchoolClass {
  id               String           @id @default(cuid())
  legacyId         String?          @unique
  academicYearId   String
  name             String
  gradeLevel       String
  section          String?
  capacity         Int              @default(40)
  classTeacherId   String?
  roomCode         String?
  inChargeName     String           @default("")
  studentCount     Int              @default(0)
  isManual         Boolean          @default(false)
  metadata         Json?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  academicYear     AcademicYear     @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  classTeacher     StaffProfile?    @relation("ClassTeacher", fields: [classTeacherId], references: [id], onDelete: SetNull)
  students         StudentProfile[]
  subjects         ClassSubject[]
  classSubjectTeachers ClassSubjectTeacher[]
  timetableSlots   TimetableSlot[]
  attendance       AttendanceSession[]
  subjectAttendanceSessions SubjectAttendanceSession[]
  assignments      Assignment[]
  exams            Exam[]
  invoices         Invoice[]

  @@unique([academicYearId, name, section])
  @@index([academicYearId, gradeLevel])
}

model StudentProfile {
  id              String            @id @default(cuid())
  userId          String            @unique
  legacyId        String?           @unique
  admissionNo     String            @unique
  rollNumber      String?
  classId         String?
  classLabel      String            @default("")
  sectionLabel    String            @default("")
  dateOfBirth     DateTime?
  gender          Gender?
  guardianNotes   String?
  bloodGroup      String?
  address         String?
  photoUrl        String?
  studentStatus   String            @default("active")
  metadata        Json?
  admissionDate   DateTime         @default(now())
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  schoolClass     SchoolClass?     @relation(fields: [classId], references: [id], onDelete: SetNull)
  guardians       StudentGuardian[]
  attendance      AttendanceRecord[]
  subjectAttendanceRecords SubjectAttendanceRecord[]
  submissions     Submission[]
  examResults     ExamResult[]
  examRecords     ExamRecord[]
  invoices        Invoice[]
  notifications   Notification[]
  performanceAlerts PerformanceAlert[]

  @@index([classId])
}

model StaffProfile {
  id              String         @id @default(cuid())
  userId          String         @unique
  legacyId        String?        @unique
  employeeNo      String         @unique
  jobTitle        String
  department      String?
  staffRole       String         @default("teacher")
  staffStatus     String         @default("active")
  address         String?
  qualification   String?
  experience      String?
  salary          String?
  emergencyContact String?
  emergencyPhone  String?
  metadata        Json?
  hireDate        DateTime       @default(now())
  dateOfBirth     DateTime?
  gender          Gender?
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  teachingClasses SchoolClass[]  @relation("ClassTeacher")
  taughtSubjects  ClassSubject[]  @relation("SubjectTeacher")
  classSubjectTeachers ClassSubjectTeacher[]
  timetableSlots  TimetableSlot[]
  attendance      AttendanceRecord[]
  attendanceSessions AttendanceSession[]
  subjectAttendanceSessions SubjectAttendanceSession[]
  teacherCheckIns TeacherCheckIn[]
  leaveRequests   TeacherLeaveRequest[]
  reviewedLeaveRequests TeacherLeaveRequest[] @relation("LeaveRequestReviewer")
  createdAssignments Assignment[]
  examRecords     ExamRecord[]
  ledgers         LedgerEntry[]
}

model GuardianProfile {
  id              String           @id @default(cuid())
  userId          String           @unique
  relationship    String?
  occupation      String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  children        StudentGuardian[]
}

model StudentGuardian {
  id          String         @id @default(cuid())
  studentId   String
  guardianId  String
  isPrimary   Boolean        @default(false)
  createdAt   DateTime       @default(now())

  student     StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  guardian    GuardianProfile @relation(fields: [guardianId], references: [id], onDelete: Cascade)

  @@unique([studentId, guardianId])
  @@index([guardianId])
}

model Subject {
  id             String         @id @default(cuid())
  academicYearId String
  code           String
  name           String
  creditHours    Int            @default(1)
  isCore         Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  academicYear   AcademicYear   @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  classes        ClassSubject[]
  classSubjectTeachers ClassSubjectTeacher[]
  timetableSlots TimetableSlot[]
  assignments    Assignment[]
  subjectAttendanceSessions SubjectAttendanceSession[]
  examRecords    ExamRecord[]
  exams          Exam[]

  @@unique([academicYearId, code])
}

model ClassSubject {
  id            String        @id @default(cuid())
  classId       String
  subjectId     String
  teacherId     String?
  weeklyPeriods Int           @default(5)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  schoolClass   SchoolClass   @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject       Subject       @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher       StaffProfile? @relation("SubjectTeacher", fields: [teacherId], references: [id], onDelete: SetNull)

  @@unique([classId, subjectId])
}

model ClassSubjectTeacher {
  id            String       @id @default(cuid())
  academicYearId String
  classId       String
  subjectId     String
  teacherId     String
  isLeadTeacher Boolean      @default(false)
  weeklyPeriods Int          @default(5)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  academicYear  AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  schoolClass   SchoolClass  @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject       Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher       StaffProfile @relation(fields: [teacherId], references: [id], onDelete: Restrict)

  @@unique([academicYearId, classId, subjectId])
  @@index([classId, subjectId])
  @@index([teacherId])
}

model TimetableSlot {
  id             String       @id @default(cuid())
  academicYearId String
  classId        String
  subjectId      String
  teacherId      String
  dayOfWeek      DayOfWeek
  periodIndex    Int
  startsAt       DateTime
  endsAt         DateTime
  roomCode       String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  schoolClass    SchoolClass  @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject        Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher        StaffProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([academicYearId, dayOfWeek, periodIndex, teacherId])
  @@unique([academicYearId, dayOfWeek, periodIndex, classId])
  @@unique([academicYearId, dayOfWeek, periodIndex, roomCode])
  @@index([classId, dayOfWeek])
  @@index([teacherId, dayOfWeek])
}

model AttendanceSession {
  id            String             @id @default(cuid())
  classId       String
  sessionDate   DateTime
  takenById     String
  notes         String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  schoolClass   SchoolClass        @relation(fields: [classId], references: [id], onDelete: Cascade)
  takenBy       StaffProfile       @relation(fields: [takenById], references: [id], onDelete: Restrict)
  records       AttendanceRecord[]

  @@unique([classId, sessionDate])
  @@index([sessionDate])
}

model AttendanceRecord {
  id            String             @id @default(cuid())
  sessionId     String
  studentId     String
  staffId       String?
  status        AttendanceStatus
  markedAt      DateTime           @default(now())
  remarks       String?

  session       AttendanceSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student       StudentProfile     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  staff         StaffProfile?      @relation(fields: [staffId], references: [id], onDelete: SetNull)

  @@unique([sessionId, studentId])
  @@index([studentId, status])
}

model Exam {
  id            String       @id @default(cuid())
  academicYearId String
  classId       String
  subjectId     String
  title         String
  status        ExamStatus    @default(draft)
  examDate      DateTime
  maxMarks      Float
  passingMarks  Float
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  academicYear  AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  schoolClass   SchoolClass  @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject       Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  results       ExamResult[]
  records       ExamRecord[]

  @@index([classId, subjectId])
}

model ExamResult {
  id          String         @id @default(cuid())
  examId      String
  studentId   String
  marksObtained Float
  grade       String?
  remarks     String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  exam        Exam           @relation(fields: [examId], references: [id], onDelete: Cascade)
  student     StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([examId, studentId])
}

model Assignment {
  id            String        @id @default(cuid())
  classId       String
  subjectId     String
  title         String
  description   String?
  dueAt         DateTime
  createdById   String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  schoolClass   SchoolClass   @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject       Subject       @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  createdBy     StaffProfile  @relation(fields: [createdById], references: [id], onDelete: Restrict)
  submissions   Submission[]
}

model Submission {
  id            String        @id @default(cuid())
  assignmentId  String
  studentId     String
  fileUrl       String?
  textAnswer    String?
  submittedAt   DateTime      @default(now())
  score         Float?
  feedback      String?

  assignment    Assignment    @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student       StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, studentId])
}

model FeeStructure {
  id            String        @id @default(cuid())
  academicYearId String
  classId       String?
  title         String
  tuitionFee    Decimal       @db.Decimal(12, 2)
  labFee        Decimal       @db.Decimal(12, 2)
  activityFee   Decimal       @db.Decimal(12, 2)
  miscFee       Decimal       @db.Decimal(12, 2)
  currency      String        @default("USD")
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  academicYear  AcademicYear  @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  invoices      Invoice[]

  @@index([academicYearId, classId])
}

model Invoice {
  id            String        @id @default(cuid())
  studentId     String
  classId       String?
  feeStructureId String?
  invoiceNo     String        @unique
  status        InvoiceStatus @default(draft)
  issuedAt      DateTime      @default(now())
  dueAt         DateTime
  totalAmount   Decimal       @db.Decimal(12, 2)
  paidAmount    Decimal       @db.Decimal(12, 2) @default(0)
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  student       StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  schoolClass   SchoolClass?   @relation(fields: [classId], references: [id], onDelete: SetNull)
  feeStructure  FeeStructure?  @relation(fields: [feeStructureId], references: [id], onDelete: SetNull)
  payments      Payment[]
  ledgerEntries LedgerEntry[]

  @@index([studentId, status])
}

model Payment {
  id            String        @id @default(cuid())
  invoiceId     String
  amount        Decimal       @db.Decimal(12, 2)
  method        PaymentMethod
  status        PaymentStatus @default(pending)
  reference     String?
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  invoice       Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId, status])
}

model LedgerEntry {
  id            String        @id @default(cuid())
  invoiceId     String?
  staffId       String?
  entryType     String
  debit         Decimal       @db.Decimal(12, 2) @default(0)
  credit        Decimal       @db.Decimal(12, 2) @default(0)
  balanceAfter  Decimal       @db.Decimal(12, 2)
  memo          String?
  createdAt     DateTime      @default(now())

  invoice       Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  staff         StaffProfile? @relation(fields: [staffId], references: [id], onDelete: SetNull)

  @@index([createdAt])
}

model Announcement {
  id            String               @id @default(cuid())
  title         String
  content       String
  priority      AnnouncementPriority @default(normal)
  publishedAt   DateTime?
  authorId      String
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  author        User                 @relation(fields: [authorId], references: [id], onDelete: Cascade)
  notifications Notification[]
}

model MessageThread {
  id            String            @id @default(cuid())
  title         String?
  type          MessageThreadType @default(direct)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  participants  MessageParticipant[]
  messages      Message[]
}

model MessageParticipant {
  id            String         @id @default(cuid())
  threadId      String
  userId        String
  lastReadAt    DateTime?
  createdAt     DateTime       @default(now())

  thread        MessageThread  @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([threadId, userId])
}

model Message {
  id            String        @id @default(cuid())
  threadId      String
  senderId      String
  body          String
  sentAt        DateTime      @default(now())
  editedAt      DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  thread        MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender        User          @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

model Notification {
  id            String      @id @default(cuid())
  studentId     String?
  userId        String?
  announcementId String?
  title         String
  body          String
  category      String
  isRead        Boolean     @default(false)
  payload       Json?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  student       StudentProfile? @relation(fields: [studentId], references: [id], onDelete: Cascade)
  user          User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  announcement  Announcement?   @relation(fields: [announcementId], references: [id], onDelete: SetNull)

  @@index([isRead, createdAt])
}

model AuditLog {
  id            String    @id @default(cuid())
  userId        String?
  action        String
  entityType    String
  entityId      String?
  metadata      Json?
  ipAddress     String?
  createdAt     DateTime  @default(now())

  user          User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
}

enum ExamRecordSeverity {
  low
  medium
  high
}

enum LeaveRequestStatus {
  pending
  approved
  rejected
  cancelled
}

enum PerformanceAlertSeverity {
  low
  medium
  high
  critical
}

model Classroom {
  id           String        @id @default(cuid())
  code         String        @unique
  name         String
  capacity     Int           @default(40)
  isAvailable  Boolean       @default(true)
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  teacherCheckIns TeacherCheckIn[]
}

model ExamCycle {
  id            String       @id @default(cuid())
  academicYearId String
  name          String
  startsAt      DateTime
  endsAt        DateTime
  isActive      Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  academicYear  AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  examTypes     ExamType[]
  examRecords   ExamRecord[]

  @@index([academicYearId, name])
}

model ExamType {
  id            String       @id @default(cuid())
  examCycleId   String
  name          String
  weight        Float
  sortOrder     Int          @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  examCycle     ExamCycle    @relation(fields: [examCycleId], references: [id], onDelete: Cascade)
  examRecords   ExamRecord[]

  @@unique([examCycleId, name])
}

model ExamRecord {
  id                     String          @id @default(cuid())
  studentId              String
  subjectId              String
  examTypeId             String
  examCycleId            String
  examId                 String?
  recordedById           String?
  marksObtained          Float
  maxMarks               Float           @default(100)
  classAverageSnapshot   Float?
  previousScoreSnapshot  Float?
  weightedCredits        Float           @default(1)
  teacherComment         String?
  gpaEquivalent          Float?
  grade                  String?
  recordedAt             DateTime        @default(now())
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  student                StudentProfile  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject                Subject         @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  examType               ExamType        @relation(fields: [examTypeId], references: [id], onDelete: Cascade)
  examCycle              ExamCycle       @relation(fields: [examCycleId], references: [id], onDelete: Cascade)
  exam                   Exam?           @relation(fields: [examId], references: [id], onDelete: SetNull)
  recordedBy             StaffProfile?   @relation(fields: [recordedById], references: [id], onDelete: SetNull)

  @@unique([studentId, subjectId, examTypeId, examCycleId])
  @@index([studentId, subjectId])
}

model SubjectAttendanceSession {
  id            String                    @id @default(cuid())
  classId       String
  subjectId     String
  sessionDate   DateTime
  teacherId     String
  notes         String?
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  schoolClass   SchoolClass               @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject       Subject                   @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher       StaffProfile              @relation(fields: [teacherId], references: [id], onDelete: Restrict)
  records       SubjectAttendanceRecord[]

  @@unique([classId, subjectId, sessionDate])
}

model SubjectAttendanceRecord {
  id            String                    @id @default(cuid())
  sessionId     String
  studentId     String
  status        AttendanceStatus
  remarks       String?
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  session       SubjectAttendanceSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student       StudentProfile            @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([sessionId, studentId])
  @@index([studentId, status])
}

model TeacherCheckIn {
  id            String        @id @default(cuid())
  teacherId     String
  classroomId   String?
  checkInAt     DateTime      @default(now())
  checkOutAt    DateTime?
  latitude      Float?
  longitude     Float?
  ipAddress     String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  teacher       StaffProfile  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  classroom     Classroom?    @relation(fields: [classroomId], references: [id], onDelete: SetNull)

  @@index([teacherId, checkInAt])
}

model TeacherLeaveRequest {
  id            String             @id @default(cuid())
  teacherId     String
  startsOn      DateTime
  endsOn        DateTime
  reason        String
  status        LeaveRequestStatus @default(pending)
  reviewedById  String?
  reviewedAt    DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  teacher       StaffProfile       @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  reviewedBy    StaffProfile?      @relation("LeaveRequestReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([teacherId, status])
}

model PerformanceAlert {
  id            String                   @id @default(cuid())
  studentId     String?
  alertType     String
  severity      PerformanceAlertSeverity
  message       String
  generatedAt   DateTime                 @default(now())
  resolvedAt    DateTime?
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  student       StudentProfile?          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([severity, generatedAt])
}


/// Login accounts for all roles (admin, teacher, parent, student, etc.).
model SystemAccount {
  id                  String    @id
  name                String
  email               String
  phone               String    @default("")
  role                String
  classDepartment     String    @default("")
  linkedStudentIds    Json?
  status              String    @default("Active")
  password            String
  createdAt           DateTime  @default(now())
  lastLoginAt         DateTime?
  credentialsIssuedAt DateTime?
  updatedAt           DateTime  @updatedAt

  @@index([role])
  @@index([email])
}

/// Transitional per-tenant key store (removed as domains move to relational tables).
model AppStorage {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

/// One row per item in former JSON array blobs (attendance, exams, finance, etc.).
model StoredJsonItem {
  id          String   @id @default(cuid())
  storageKey  String
  legacyId    String
  sortOrder   Int      @default(0)
  payload     Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([storageKey, legacyId])
  @@index([storageKey, sortOrder])
}

/// One row per former JSON object / settings blob.
model StoredJsonSingleton {
  storageKey  String   @id
  payload     Json
  updatedAt   DateTime @updatedAt
}
