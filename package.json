{
  "name": "school-management-system",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate --schema prisma/catalog/schema.prisma && prisma generate --schema prisma/tenant/schema.prisma",
    "db:migrate": "prisma migrate dev --schema prisma/catalog/schema.prisma",
    "db:deploy": "prisma migrate deploy --schema prisma/catalog/schema.prisma",
    "db:deploy:tenants": "tsx scripts/deploy-tenant-schemas.ts",
    "db:migrate:legacy": "tsx scripts/migrate-legacy-to-multi-db.ts",
    "db:backups:run": "tsx scripts/run-scheduled-backups.ts",
    "db:migrate:students": "tsx scripts/migrate-students-to-relational.ts",
    "db:migrate:core": "tsx scripts/migrate-core-to-relational.ts",
    "db:migrate:documents": "tsx scripts/migrate-student-documents-to-cloudinary.ts",
    "db:studio": "prisma studio --schema prisma/catalog/schema.prisma",
    "db:studio:tenant": "prisma studio --schema prisma/tenant/schema.prisma",
    "db:seed": "prisma db seed"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.24.0",
    "@prisma/client": "^6.9.0",
    "@tanstack/react-query": "^5.59.0",
    "@whiskeysockets/baileys": "^7.0.0-rc13",
    "bufferutil": "^4.1.0",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.10.0",
    "clsx": "^2.1.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.471.0",
    "next": "^14.2.31",
    "nodemailer": "^9.0.3",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.0",
    "tailwind-merge": "^2.5.5",
    "utf-8-validate": "^6.0.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^8.0.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.35",
    "postcss": "^8.5.1",
    "prisma": "^6.9.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
