# Copy to .env on the VPS before `npm run build`
# PostgreSQL (local on Oracle VM)
DATABASE_URL=postgresql://schoolapp:CHANGE_ME@localhost:5432/school_management

# Enable shared PostgreSQL storage (required for production hosting)
USE_DATABASE=true
NEXT_PUBLIC_USE_DATABASE=true

# App
NODE_ENV=production
PORT=3000

# Phase 1 testing: email + WhatsApp credentials are configured in
# Admin -> Settings -> Communication (stored per school in PostgreSQL).
# Optional server-only overrides are not required for the current test setup.
