# Catalog database (school registry)
CATALOG_DATABASE_URL=postgresql://schoolapp:CHANGE_ME@localhost:5432/school_catalog

# Legacy fallback — only used if CATALOG_DATABASE_URL is unset
DATABASE_URL=postgresql://schoolapp:CHANGE_ME@localhost:5432/school_catalog

# Superuser connection used to CREATE/DROP per-school databases
POSTGRES_ADMIN_URL=postgresql://postgres:CHANGE_ME@localhost:5432/postgres

# Per-tenant schema push/migrate commands set this dynamically
TENANT_DATABASE_URL=postgresql://schoolapp:CHANGE_ME@localhost:5432/sms_school_example

# Old single-database URL for one-time migration from school_management
LEGACY_DATABASE_URL=postgresql://schoolapp:CHANGE_ME@localhost:5432/school_management

# Enable shared PostgreSQL storage (required for production hosting)
USE_DATABASE=true
NEXT_PUBLIC_USE_DATABASE=true

# Cloudinary (student document uploads — files stored in Cloudinary, URLs in PostgreSQL)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# App
NODE_ENV=production
PORT=3000

# Phase 1 testing: email + WhatsApp credentials are configured in
# Admin -> Settings -> Communication (stored per school in that school's database).
